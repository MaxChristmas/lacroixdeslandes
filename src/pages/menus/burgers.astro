---
import MenuLayout from '../../layouts/MenuLayout.astro';

const burgers = [
  { name: "Le Chèvre", price: "11,90€", desc: "Pain burger, steak Angus, sauce pita, sauce barbecue, tomate locale, salade locale, fromage de chèvre, cheddar, oignons frits.", image: "/images/burger-chevre.webp" },
  { name: "Le Classique", price: "11,90€", desc: "Pain burger, steak haché Angus, lard frit, oignons rouges, sauce burger, cornichons, cheddar, salade locale, sauce pita, tomate locale.", image: "/images/burger-classique.webp" },
  { name: "Le Old Jock", price: "11,90€", desc: "Pain burger, steak haché Angus, oignons frits, tomates locale, Tomme, salade locale, sauce tartare, sauce pita.", image: "/images/burger-old-jock.webp" },
  { name: "Ar Poualed", price: "11,90€", desc: "Pain burger, tenders de poulet maison Français, sauce curry, oignons frits, salade locale, tomates locale, Tomme, sauce pita.", image: "/images/burger-ar-poualed.webp" },
  { name: "Le Klasel", price: "11,90€", desc: "Pain burger, steak haché Angus, oignons rouges, sauce tartare, salade locale, tomates locale, Camembert, sauce pita.", image: "/images/burger-klasel.webp" },
  { name: "Le Rozel", price: "11,90€", desc: "Pain burger, steak haché Angus, oignons rouges, salade locale, tomates locale, fromage à raclette, sauce burger, bacon, sauce pita.", image: "/images/burger-rozel.webp" },
  { name: "Le Sen Koko", price: "11,90€", desc: "Pain burger, steak haché de Charolais, sauce barbecue, Roquefort, Cheddar, tomates locale, salade locale, cornichons, sauce pita.", image: "/images/burger-sen-koko.webp" },
  { name: "Le P'tit Gorgonnais (enfant)", price: "11,60€", desc: "Pain burger bio, steak haché de Charolais, tomates locale, Cheddar, sauce burger, sauce pita.", image: "/images/burger-ptit-gorgonais.webp" },
  { name: "Le Breton", price: "11,90€", desc: "Pain burger au sarrazin, andouille de Bretagne, effiloché de porc maison, oignons frits, tomate locale, salade locale.", image: "/images/burger-sen-koko.webp" },
];

const menuItemsSchema = {
  "@context": "https://schema.org",
  "@type": "Menu",
  "name": "Carte des Burgers",
  "hasMenuSection": {
    "@type": "MenuSection",
    "name": "Burgers",
    "hasMenuItem": burgers.map(burger => ({
      "@type": "MenuItem",
      "name": burger.name,
      "description": burger.desc,
      "image": `https://lacroixdeslandes.fr${burger.image}`,
      "offers": {
        "@type": "Offer",
        "price": burger.price.replace('€', '').replace(',', '.').trim(),
        "priceCurrency": "EUR"
      }
    }))
  }
};
---

<MenuLayout
  title="Nos Burgers"
  pageTitle="Nos burgers"
  description="Tous nos burgers sont conçus avec du pain bio et garnis principalement de produits locaux et issus de culture biologique."
  intro="Tous nos burgers sont conçus avec du pain bio et garnis principalement de produits locaux et issus de culture biologique."
  wide
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(menuItemsSchema)} />
  </Fragment>

  <section class="mb-12 text-neutral-700 text-base leading-relaxed max-w-3xl mx-auto">
    <h2 class="text-2xl mb-4">Des burgers artisanaux à Saint-Gorgon</h2>
    <p class="mb-4">À La Croix des Landes, nos burgers sont bien plus qu'un simple repas rapide. Chaque burger est préparé à la commande avec du <strong>pain bio</strong> et des ingrédients soigneusement sélectionnés auprès de <strong>producteurs locaux du Morbihan</strong>. Notre viande de Charolais et d'Angus est sélectionnée avec soin, et nos légumes — tomates, salades, oignons — sont de provenance Bretonne et locale.</p>
    <p>Du classique au plus gourmand, notre carte de 9 burgers propose des associations de saveurs variées : chèvre et oignons frits, Roquefort et Cheddar, raclette et bacon, ou encore notre Breton à l'andouille de Bretagne et effiloché de porc maison. Tous sont servis avec des frites Bretonnes et disponibles <strong>sur place ou à emporter</strong>.</p>
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {burgers.map(burger => {
      const src512 = burger.image.replace('.webp', '-512w.webp');
      return (
        <div class="card overflow-hidden text-center">
          <img
            src={burger.image}
            srcset={`${src512} 512w, ${burger.image} 1024w`}
            sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
            alt={`Burger ${burger.name} fait maison au restaurant La Croix des Landes à Saint-Gorgon`}
            class="w-full h-56 object-cover"
            loading="lazy"
            width="1024"
            height="1024"
          />
          <div class="p-6">
            <div class="text-neutral-800 font-semibold text-lg mb-1">{burger.price}</div>
            <h3 class="text-xl mb-3">{burger.name}</h3>
            <p class="text-neutral-600 text-sm leading-relaxed">{burger.desc}</p>
            <hr class="border-neutral-300 mt-6 mx-auto w-16" />
          </div>
        </div>
      );
    })}
  </div>
</MenuLayout>
