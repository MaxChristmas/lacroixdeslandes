---
import MenuLayout from '../../layouts/MenuLayout.astro';
---

<MenuLayout
  title="Menu à la carte"
  pageTitle="Le menu à la carte"
  price="29,80 €"
  note="Menu exclusivement sur réservation"
>
  <div class="card p-6 sm:p-10 lg:p-18">
    <!-- Entrées -->
    <div>
      <h2 class="text-2xl mb-4">Entrées</h2>
      <ul class="space-y-3">
        <li class="text-neutral-600 text-base sm:text-lg">Salade gourmande avec jambon, reblochon, tomates bio</li>
        <li class="text-neutral-600 text-base sm:text-lg">Dos de colin rôti avec sauce et garniture</li>
        <li class="text-neutral-600 text-base sm:text-lg">Effiloché de raie avec sauce et garniture</li>
        <li class="text-neutral-600 text-base sm:text-lg">Filet de saint pierre avec sauce et garniture</li>
      </ul>
    </div>

    <hr class="border-neutral-300 my-8" />

    <!-- Plats -->
    <div>
      <h2 class="text-2xl mb-4">Plats</h2>
      <ul class="space-y-3">
        <li class="text-neutral-600 text-base sm:text-lg">Carbonnade de bœuf français en cocotte</li>
        <li class="text-neutral-600 text-base sm:text-lg">Cuissot de porcelet français cuit au feu de bois</li>
        <li class="text-neutral-600 text-base sm:text-lg">Ballotine de poulet français</li>
      </ul>
    </div>

    <hr class="border-neutral-300 my-8" />

    <!-- Fromage -->
    <div>
      <h2 class="text-2xl mb-4">Fromage <span class="text-red-lcdl font-medium text-lg">(supplément 3€)</span></h2>
      <p class="text-neutral-600 text-base sm:text-lg">Duo de fromage avec salade de saison</p>
    </div>

    <hr class="border-neutral-300 my-8" />

    <!-- Desserts -->
    <div>
      <h2 class="text-2xl mb-4">Desserts</h2>
      <ul class="space-y-3">
        <li class="text-neutral-600 text-base sm:text-lg">Assiette de gourmandises</li>
        <li class="text-neutral-600 text-base sm:text-lg">Gâteau pâtissier <span class="text-red-lcdl font-medium">(supplément 3€)</span></li>
      </ul>
    </div>
  </div>
</MenuLayout>
