---
import Layout from '../layouts/Layout.astro';
import OpenStatusBadge from '../components/OpenStatusBadge.astro';
import { getMenusSemaine } from '../lib/menus-semaine';

const menusSemaine = await getMenusSemaine();
import menuCategories from '../data/menu-categories.json';
import services from '../data/services.json';
import reviews from '../data/reviews.json';
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quels sont les horaires du restaurant La Croix des Landes ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le restaurant est ouvert du lundi au dimanche de 09h30 à 21h00. Les horaires peuvent varier selon les saisons, consultez notre page Google pour les horaires en temps réel."
      }
    },
    {
      "@type": "Question",
      "name": "Comment réserver une table à La Croix des Landes ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pour réserver une table, appelez-nous au 02 99 71 93 68 ou envoyez un email à lacroixdeslandes@orange.fr. La réservation est obligatoire pour le menu du chef et le menu à la carte."
      }
    },
    {
      "@type": "Question",
      "name": "Le restaurant propose-t-il des formules traiteur ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, La Croix des Landes propose des prestations traiteur pour vos événements de 10 à 300 personnes : repas de famille, mariages, séminaires d'entreprise. Contactez-nous au 02 99 71 93 68 pour un devis."
      }
    },
    {
      "@type": "Question",
      "name": "Où est situé le restaurant La Croix des Landes ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le restaurant est situé Rue de la Croix des Landes, 56350 Saint-Gorgon, dans le Morbihan (Bretagne)."
      }
    },
    {
      "@type": "Question",
      "name": "Quels types de cuisine sont proposés à La Croix des Landes ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nous proposons une cuisine traditionnelle française fait maison avec des produits locaux : menus du jour, menus du chef, menu à la carte, burgers et pizzas. Tous nos plats sont préparés sur place."
      }
    }
  ]
};
---

<Layout title="Restaurant à Saint-Gorgon | La Croix des Landes (Morbihan) – Fait Maison & Produits Locaux">
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- HERO SECTION -->
  <section class="relative min-h-[90vh] flex flex-col justify-center overflow-hidden">
    <!-- Background image -->
    <img
      src="/images/restaurant-facade.webp"
      alt="Façade du restaurant La Croix des Landes"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Overlay gradient -->
    <div class="absolute inset-0 bg-linear-to-t from-neutral-800/90 via-neutral-800/40 to-neutral-800/10"></div>

    <!-- Content -->
    <div class="relative z-10 container-default pb-16 lg:pb-24 pt-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-8 lg:gap-12 items-center">

        <!-- Left: Text -->
        <div>
          <div class="mb-6">
            <div class="line-accent _124px white"></div>
          </div>
          <h1 class="text-neutral-100 text-[30px] sm:text-[42px] md:text-[52px] leading-tight mb-4">
            Cuisine et produits locaux, ici le fait-maison a vraiment du goût.
          </h1>
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-8">
            <p class="text-neutral-100 text-[16px] sm:text-[18px] font-medium">
              Restaurant à Saint-Gorgon
            </p>
            <OpenStatusBadge variant="dark" />
          </div>
          <div class="flex flex-col sm:flex-row items-center gap-4">
            <a href="tel:0299719368" class="btn-primary red-button w-full sm:w-auto text-center">
              02 99 71 93 68
            </a>
            <a href="/#menus" class="btn-secondary w-full sm:w-auto text-center border-neutral-100! text-neutral-100! hover:bg-neutral-100! hover:text-neutral-800!">
              Voir les menus
            </a>
          </div>
          <!-- Rating -->
          <div class="mt-8">
            <a href="https://maps.app.goo.gl/jtMJ3LKNJKhHaKpP8" target="_blank" rel="noopener"
              class="flex items-center gap-2 hover:opacity-80 transition-opacity">
              <span class="text-yellow-400 text-xl">★★★★★</span>
              <span class="text-neutral-100 font-semibold">4.7 / 5</span>
              <span class="hidden sm:inline text-neutral-500 text-sm">· 61 avis Google</span>
            </a>
          </div>
        </div>

        <!-- Right: Menu du jour -->
        <div class="bg-neutral-900/60 backdrop-blur-md border border-neutral-600/50 p-6 sm:p-10 lg:p-14 text-center">
          <div class="mb-1">
            <div class="text-sm font-semibold uppercase tracking-widest text-neutral-400 mb-4">Aujourd'hui</div>
            <h3 class="text-red-lcdl text-3xl font-semibold">Le menu du jour</h3>
          </div>
          <div class="w-12 h-px bg-neutral-600 mx-auto my-6"></div>
          <div id="menu-du-jour-wrapper" style="visibility: hidden;">
            {menusSemaine.map(menu => (
              <div data-day-index={menu.dayIndex} class="hidden">
                <div class="text-neutral-100 font-medium lowercase first-letter:uppercase mb-4 text-lg">{menu.label}</div>
                <p class="text-neutral-300 leading-relaxed">{menu.description}</p>
              </div>
            ))}
          </div>
          <div class="mt-6 text-neutral-400 text-sm leading-relaxed">
            Également : <strong class="text-neutral-300">pièce de boucher</strong>, <strong class="text-neutral-300">anguille de Loire</strong>, <strong class="text-neutral-300">burgers</strong> et le weekend nos <strong class="text-neutral-300">pizzas</strong>.
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- DISCOVER MENUS SECTION -->
  <section id="menus" class="section pt-16! lg:pt-20! bg-neutral-800">
    <div class="container-default">
      <div class="text-center mb-16">
        <div class="mb-6 flex justify-center">
          <div class="line-accent _124px white"></div>
        </div>
        <h2 class="text-neutral-100 mb-4">Découvrez nos menus</h2>
        <div class="max-w-[552px] mx-auto">
          <p class="text-neutral-400">Nos menus sont disponibles sur place ou à emporter dans la limite des heures d'ouvertures et de la disponibilité des produits.</p>
        </div>
      </div>

      <!-- Menu cards carousel -->
      <div class="relative">
        <!-- Arrow left -->
        <button
          id="carousel-prev"
          class="hidden lg:flex absolute -left-16 top-1/2 -translate-y-1/2 z-10 w-12 h-12 items-center justify-center border border-neutral-400 text-neutral-100 hover:bg-neutral-100 hover:text-neutral-800 transition-colors"
          aria-label="Précédent"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>

        <!-- Slides -->
        <div id="carousel-track" class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory scrollbar-hide">
          {menuCategories.map(cat => (
            <a href={cat.href} class="group flex-shrink-0 w-[85%] sm:w-[45%] lg:w-[calc(50%-12px)] flex flex-col bg-neutral-100 overflow-hidden transition-transform hover:scale-[0.98] snap-start">
              <div class="aspect-[16/10] overflow-hidden">
                <img src={cat.image} alt={cat.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="p-6 flex flex-col flex-1">
                <h3 class="text-xl mb-3">{cat.title}</h3>
                <p class="text-neutral-600 text-sm mb-6">{cat.description}</p>
                <div class="mt-auto">
                  <span class="text-neutral-800 font-medium uppercase tracking-wider text-sm flex items-center gap-2">
                    {cat.linkText}
                    <span class="transition-transform group-hover:translate-x-1">→</span>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Arrow right -->
        <button
          id="carousel-next"
          class="hidden lg:flex absolute -right-16 top-1/2 -translate-y-1/2 z-10 w-12 h-12 items-center justify-center border border-neutral-400 text-neutral-100 hover:bg-neutral-100 hover:text-neutral-800 transition-colors"
          aria-label="Suivant"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>

      <!-- Carousel script -->
      <script is:inline>
        (function() {
          const track = document.getElementById('carousel-track');
          const prev = document.getElementById('carousel-prev');
          const next = document.getElementById('carousel-next');
          if (!track || !prev || !next) return;

          const scrollAmount = () => track.querySelector('a')?.offsetWidth + 24 || 400;

          prev.addEventListener('click', () => {
            track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
          });
          next.addEventListener('click', () => {
            track.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
          });
        })();
      </script>
    </div>
  </section>

  <!-- TRAITEUR SECTION -->
  <section class="section">
    <div class="container-default">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="mb-8">
            <div class="line-accent _124px"></div>
          </div>
          <h2 class="mb-6">Notre offre traiteur</h2>
          <div class="max-w-[480px]">
            <p class="mb-12">A votre disposition pour organiser vos repas de famille, baptême, anniversaire grâce à notre offre traiteur. De 10 à 300 convives, notre équipe peut répondre à vos demandes.</p>
          </div>
          <a href="/menus/menus-traiteur" class="btn-secondary">Voir Notre Offre</a>
        </div>
        <div>
          <img
            src="/images/traiteur.webp"
            alt="Buffet présenté par la croix des landes"
            class="w-full object-cover"
            width="800"
            height="1067"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <div class="-mt-20 lg:-mt-56">
    <section id="contact" class="section relative py-0!">
      <div class="relative z-10">
        <div class="container-default">
          <div class="bg-neutral-100 shadow-[0_4px_24px_0_var(--color-shadow-01)] flex flex-col lg:flex-row justify-between py-10 lg:py-20 px-6 lg:px-16">
            <!-- Contact -->
            <div class="max-w-[285px] w-full flex flex-col mb-8 lg:mb-0">
              <div class="mb-9">
                <h2 class="uppercase text-200 tracking-wider font-medium mb-8">Nous contacter</h2>
                <div class="space-y-4">
                  <div class="flex flex-wrap justify-between items-center gap-2">
                    <span class="text-200 font-medium text-neutral-800">Téléphone:</span>
                    <a href="tel:0299719368" class="link-wrapper">
                      <span class="link-text text-sm">02 99 71 93 68</span>
                    </a>
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="text-200 font-medium text-neutral-800">Email:</span>
                    <a href="mailto:lacroixdeslandes@orange.fr" class="link-text text-sm break-all">lacroixdeslandes@orange.fr</a>
                  </div>
                </div>
              </div>
              <div class="mt-auto text-neutral-800 font-medium text-sm">
                Réservation de préférence par téléphone ou sur place
              </div>
            </div>

            <!-- Divider -->
            <div class="hidden lg:block w-px bg-neutral-300 mx-6"></div>
            <div class="lg:hidden h-px bg-neutral-300 my-6"></div>

            <!-- Location -->
            <div class="max-w-[228px] flex flex-col mb-8 lg:mb-0">
              <div class="mb-9">
                <h2 class="uppercase text-200 tracking-wider font-medium mb-8">Localisation</h2>
                <div class="space-y-1">
                  <div>Rue de la Croix des Landes</div>
                  <div>56350 Saint Gorgon</div>
                </div>
              </div>
            </div>

            <!-- Divider -->
            <div class="hidden lg:block w-px bg-neutral-300 mx-6"></div>
            <div class="lg:hidden h-px bg-neutral-300 my-6"></div>

            <!-- Hours note -->
            <div class="max-w-[285px] w-full flex flex-col">
              <div class="mt-auto text-neutral-800 font-medium text-sm">
                Pour les vacances et jours fériés, merci de vous référer aux heures affichées sur Google
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- SERVICES SECTION -->
  <section id="services" class="section bg-neutral-200">
    <div class="container-default">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-16 gap-6">
        <div>
          <div class="mb-8">
            <div class="line-accent _124px"></div>
          </div>
          <h2 class="mb-0">Nos Services Annexes</h2>
        </div>
        <p class="max-w-[480px]">Tous ses services sont disponibles sur place et pendant les heures d'ouvertures du restaurant.</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-6">
        {services.map(service => (
          <div class="card p-4 sm:p-8">
            <img src={service.icon} alt={service.alt} class="mb-3 h-8 sm:h-12" loading="lazy" />
            <h3 class="text-base sm:text-xl mb-1 sm:mb-2">{service.title}</h3>
            <p class="text-neutral-600 text-sm sm:text-base">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM SECTION -->
  <section id="team" class="section bg-neutral-800">
    <div class="container-default">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Team photo -->
        <div class="max-w-[625px]">
          <img
            src="/images/team.webp"
            alt="Photo de l'équipe la croix des landes"
            class="w-full object-cover"
            width="900"
            height="675"
            loading="lazy"
          />
        </div>

        <!-- Team text -->
        <div>
          <div class="mb-8">
            <div class="line-accent _124px white"></div>
          </div>
          <h2 class="text-neutral-100 mb-6">L'équipe de<br />La Croix Des Landes</h2>
          <p class="text-neutral-400 leading-relaxed">
            Nous vous souhaitons la bienvenue à <strong class="text-neutral-100">la Croix Des Landes</strong> où nous sommes heureux de vous accueillir. Sachez que nous pouvons aussi vous proposer differentes prestations pour vos repas de famille, baptême, communion, anniversaire, mariage, repas d'association. De 10 à 300 convives notre équipe peut répondre à vos demandes.
            <br /><br />
            Toute notre équipe se tient prête pour organiser cette journée importante en fonction de vos envies et de vos désirs. Vous pouvez nous joindre au <strong class="text-neutral-100">02 99 71 93 68</strong> pour planifier cet évènement et convenir d'un rendez-vous si vous le souhaitez.
            <br /><br />
            Nous vous souhaitons de passer un <strong class="text-neutral-100">bon moment et un bon appétit!</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS SECTION -->
  <section class="section bg-neutral-200">
    <div class="container-default">

      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-10">
        <div>
          <div class="mb-6">
            <div class="line-accent _124px"></div>
          </div>
          <h2 class="mb-0">Ce que nos clients disent de nous.</h2>
        </div>
        <a href="https://www.google.com/search?q=la+croix+des+landes+saint+gorgon" target="_blank" rel="noopener" class="btn-primary red-button shrink-0">
          Laisser un avis
        </a>
      </div>

      <!-- Bento grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <!-- [0] Cathy — col1 row1 -->
        <div class="card shadow-long p-7 flex flex-col gap-4">
          <span class="text-yellow-400 text-lg">★★★★★</span>
          <p class="text-neutral-700 leading-relaxed flex-1">"{reviews[0].text}"</p>
          <div class="text-neutral-800 font-semibold text-sm">— {reviews[0].author}</div>
        </div>

        <!-- [4] Dorian — col2 row1-2, featured dark card -->
        <div class="shadow-long p-8 rounded-xl bg-neutral-800 md:row-span-2 flex flex-col gap-6">
          <span class="text-yellow-400 text-lg">★★★★★</span>
          <p class="text-neutral-100 text-lg leading-relaxed flex-1">"{reviews[4].text}"</p>
          <div class="text-neutral-400 font-semibold text-sm">— {reviews[4].author}</div>
        </div>

        <!-- [3] Morgane — col3 row1 -->
        <div class="card shadow-long p-7 flex flex-col gap-4">
          <span class="text-yellow-400 text-lg">★★★★★</span>
          <p class="text-neutral-700 leading-relaxed flex-1">"{reviews[3].text}"</p>
          <div class="text-neutral-800 font-semibold text-sm">— {reviews[3].author}</div>
        </div>

        <!-- [1] Sylvain — col1 row2 -->
        <div class="card shadow-long p-7 flex flex-col gap-4">
          <span class="text-yellow-400 text-lg">★★★★★</span>
          <p class="text-neutral-700 leading-relaxed flex-1">"{reviews[1].text}"</p>
          <div class="text-neutral-800 font-semibold text-sm">— {reviews[1].author}</div>
        </div>

        <!-- [5] Laurence — col3 row2 -->
        <div class="card shadow-long p-7 flex flex-col gap-4">
          <span class="text-yellow-400 text-lg">★★★★★</span>
          <p class="text-neutral-700 leading-relaxed flex-1">"{reviews[5].text}"</p>
          <div class="text-neutral-800 font-semibold text-sm">— {reviews[5].author}</div>
        </div>

        <!-- [2] François — col1-2 row3, wide accent -->
        <div class="card shadow-long p-7 md:col-span-2 flex flex-col gap-4">
          <span class="text-yellow-400 text-lg">★★★★★</span>
          <p class="text-neutral-700 leading-relaxed flex-1">"{reviews[2].text}"</p>
          <div class="text-neutral-800 font-semibold text-sm">— {reviews[2].author}</div>
        </div>

        <!-- [6] Rob — col3 row3 -->
        <div class="card shadow-long p-7 flex flex-col gap-4">
          <span class="text-yellow-400 text-lg">★★★★★</span>
          <p class="text-neutral-700 leading-relaxed flex-1">"{reviews[6].text}"</p>
          <div class="text-neutral-800 font-semibold text-sm">— {reviews[6].author}</div>
        </div>

      </div>
    </div>
  </section>

  <!-- FACEBOOK SECTION -->
  <section class="section bg-neutral-200 pt-0!">
    <div class="container-default">

      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-10">
        <div>
          <div class="mb-6">
            <div class="line-accent _124px"></div>
          </div>
          <h2 class="mb-0">Suivez nous sur Facebook</h2>
        </div>
        <div class="flex flex-wrap gap-4 shrink-0">
          <a href="https://m.me/100063678783204" target="_blank" rel="noopener" class="btn-primary">💬 Messenger</a>
          <a href="https://www.facebook.com/people/La-croix-des-landes/100063678783204/?locale=fr_FR" target="_blank" rel="noopener" class="btn-primary">Facebook</a>
        </div>
      </div>

      <!-- Bento grid photos -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <!-- col1 row1 -->
        <a href="https://www.facebook.com/people/La-croix-des-landes/100063678783204/" target="_blank" rel="noopener" class="overflow-hidden rounded-xl aspect-square group">
          <img src="/images/photos/Amalia_1769958458224.webp" alt="Plat servi au restaurant La Croix des Landes à Saint-Gorgon" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
        </a>

        <!-- col2 row1-2, featured tall -->
        <a href="https://www.facebook.com/people/La-croix-des-landes/100063678783204/" target="_blank" rel="noopener" class="overflow-hidden rounded-xl md:row-span-2 group">
          <img src="/images/photos/Jade_1771073800811.webp" alt="Salle du restaurant La Croix des Landes, ambiance conviviale" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
        </a>

        <!-- col3 row1 -->
        <a href="https://www.facebook.com/people/La-croix-des-landes/100063678783204/" target="_blank" rel="noopener" class="overflow-hidden rounded-xl aspect-square group">
          <img src="/images/photos/Lindsay_1770551532528.webp" alt="Assiette fait maison au restaurant La Croix des Landes" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
        </a>

        <!-- col1 row2 -->
        <a href="https://www.facebook.com/people/La-croix-des-landes/100063678783204/" target="_blank" rel="noopener" class="overflow-hidden rounded-xl aspect-square group">
          <img src="/images/photos/Emma_1770470435301.webp" alt="Repas en famille au restaurant La Croix des Landes" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
        </a>

        <!-- col3 row2 -->
        <a href="https://www.facebook.com/people/La-croix-des-landes/100063678783204/" target="_blank" rel="noopener" class="overflow-hidden rounded-xl aspect-square group">
          <img src="/images/photos/Jean_1770985934919.webp" alt="Cuisine locale et produits du terroir à La Croix des Landes" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
        </a>

        <!-- col1-2 row3, wide -->
        <a href="https://www.facebook.com/people/La-croix-des-landes/100063678783204/" target="_blank" rel="noopener" class="overflow-hidden rounded-xl md:col-span-2 aspect-video group">
          <img src="/images/photos/Jerome_1770985995012.webp" alt="Terrasse et extérieur du restaurant La Croix des Landes à Saint-Gorgon" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
        </a>

        <!-- col3 row3 -->
        <a href="https://www.facebook.com/people/La-croix-des-landes/100063678783204/" target="_blank" rel="noopener" class="overflow-hidden rounded-xl aspect-square group">
          <img src="/images/photos/Maxime_1770294935629.webp" alt="Dessert maison au restaurant La Croix des Landes" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
        </a>

      </div>
    </div>
  </section>

  <!-- Day menu display script -->
  <script is:inline>
    (function () {
      function dayIndex1to7(date) {
        const js = date.getDay();
        return js === 0 ? 7 : js;
      }

      function nowInParis() {
        const parts = new Intl.DateTimeFormat('fr-FR', {
          timeZone: 'Europe/Paris',
          year: 'numeric', month: '2-digit', day: '2-digit',
          hour: '2-digit', minute: '2-digit', second: '2-digit',
          hour12: false
        }).formatToParts(new Date()).reduce((acc, p) => (acc[p.type] = p.value, acc), {});
        return new Date(`${parts.year}-${parts.month}-${parts.day}T${parts.hour}:${parts.minute}:${parts.second}`);
      }

      const today = dayIndex1to7(nowInParis());

      document.querySelectorAll('[data-day-index]').forEach(el => {
        const idx = parseInt(el.getAttribute('data-day-index'), 10);
        if (idx === today) {
          el.classList.remove('hidden');
        }
      });

      const wrapper = document.getElementById('menu-du-jour-wrapper');
      if (wrapper) wrapper.style.visibility = 'visible';
    })();

  </script>
</Layout>
