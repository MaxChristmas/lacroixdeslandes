---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Restaurant traditionnel à Saint-Gorgon (Morbihan). Cuisine fait maison, produits locaux, menus du jour, burgers, pizzas & options traiteur. Réservez au 02 99 71 93 68.",
  ogImage = "/images/og-image.jpg"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://www.lacroixdeslandes.fr');
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="PaoANhbbZW5XpS_UfTbbJ9omBjIoCueEblJnvC_8F00" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, 'https://www.lacroixdeslandes.fr').href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, 'https://www.lacroixdeslandes.fr').href} />

    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/webclip.svg" />
    <link rel="canonical" href={canonicalURL.href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": "La Croix des Landes",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Rue de la Croix des Landes",
        "addressLocality": "Saint-Gorgon",
        "postalCode": "56350",
        "addressCountry": "FR"
      },
      "telephone": "02 99 71 93 68",
      "servesCuisine": ["Française", "Burgers", "Pizzas"],
      "priceRange": "€€",
      "url": "https://www.lacroixdeslandes.fr/",
      "openingHours": "Mo–Su 09:30–21:00"
    })} />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BL14G053VR"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BL14G053VR');
    </script>
  </head>
  <body>
    <div class="min-h-screen">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
