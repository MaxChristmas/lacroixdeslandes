---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Restaurant traditionnel à Saint-Gorgon (Morbihan). Cuisine fait maison, produits locaux, menus du jour, burgers, pizzas & options traiteur. Réservez au 02 99 71 93 68.",
  ogImage = "/images/og-image.jpg"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://lacroixdeslandes.fr');
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="PaoANhbbZW5XpS_UfTbbJ9omBjIoCueEblJnvC_8F00" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="La Croix des Landes" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, 'https://lacroixdeslandes.fr').href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, 'https://lacroixdeslandes.fr').href} />

    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/webclip.svg" />
    <link rel="canonical" href={canonicalURL.href} />

    <slot name="head" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": "La Croix des Landes",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Rue de la Croix des Landes",
        "addressLocality": "Saint-Gorgon",
        "postalCode": "56350",
        "addressCountry": "FR"
      },
      "url": "https://lacroixdeslandes.fr/",
      "logo": "https://lacroixdeslandes.fr/images/logo.webp",
      "image": "https://lacroixdeslandes.fr/images/restaurant-facade.webp",
      "description": "Restaurant traditionnel à Saint-Gorgon (Morbihan). Cuisine fait maison, produits locaux, menus du jour, burgers, pizzas & options traiteur.",
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 47.6897,
        "longitude": -2.2014
      },
      "telephone": "+33299719368",
      "email": "lacroixdeslandes@orange.fr",
      "servesCuisine": ["Cuisine française traditionnelle", "Burgers", "Pizzas", "Traiteur"],
      "priceRange": "€€",
      "currenciesAccepted": "EUR",
      "paymentAccepted": "Cash, Credit Card",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
          "opens": "09:30",
          "closes": "21:00"
        }
      ],
      "hasMenu": "https://lacroixdeslandes.fr/menus/menus-a-la-carte/",
      "sameAs": [
        "https://www.facebook.com/people/La-croix-des-landes/100063678783204/"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.7",
        "reviewCount": 61,
        "bestRating": "5"
      },
      "review": [
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Cathy" },
          "datePublished": "2025-07-01",
          "reviewBody": "Très bon accueil. très bonne cuisine agréablement surpris, excellent.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Sylvain" },
          "datePublished": "2025-08-01",
          "reviewBody": "Excellent restaurant ouvrier ! Rapport qualité prix au rendez-vous!",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "François" },
          "datePublished": "2025-09-01",
          "reviewBody": "Charmant petit restaurant de village. rapport qualité prix imbattable. Service rapide avec le sourire. Grand choix d'entrées et de desserts.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Morgane" },
          "datePublished": "2025-11-01",
          "reviewBody": "Prix attractif et le personnel est vraiment très sympathique.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Dorian" },
          "datePublished": "2025-11-01",
          "reviewBody": "Excellent restaurant ! Les plats sont préparés avec des produits bio et locaux, accueil chaleureux des serveuses et prix imbattable ! Je recommande vivement.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Laurence" },
          "datePublished": "2025-10-01",
          "reviewBody": "Je recommande ce restaurant car le personnel est très agréable et très serviable. Les plats sont faits maison et sont très bons.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Rob" },
          "datePublished": "2025-10-01",
          "reviewBody": "Excellent restaurant, a warm welcome, friendly professional service and fabulous food.",
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
        }
      ]
    })} />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-BL14G053VR"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BL14G053VR');
    </script>
  </head>
  <body>
    <div class="min-h-screen">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
